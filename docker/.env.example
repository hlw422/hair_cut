# ===========================================
# HairCut 开发环境变量配置示例
# ===========================================

# MySQL 数据库
MYSQL_ROOT_PASSWORD=haircut_root_2024
MYSQL_DB=haircut
MYSQL_USER=haircut_user
MYSQL_PASSWORD=haircut_dev_2024
MYSQL_PORT=3306

# Redis 缓存
REDIS_PASSWORD=haircut_redis_2024
REDIS_PORT=6379

# Elasticsearch 搜索引擎
ES_PORT=9200
ES_PORT_TRANSPORT=9300
KIBANA_PORT=5601

# MongoDB 文档数据库
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=mongo_admin_2024
MONGO_DB=haircut_logs
MONGO_PORT=27017

# RabbitMQ 消息队列
RABBITMQ_USER=haircut
RABBITMQ_PASSWORD=rabbitmq_2024
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MinIO 对象存储
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_2024
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 应用服务端口
SERVER_API_PORT=8080
ADMIN_WEB_PORT=5173
WEBSITE_PORT=3000

# JWT 密钥（生产环境请更换为强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRE_HOURS=24

# 微信小程序配置（请在微信公众平台获取）
WECHAT_APP_ID=wx_your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# 微信支付配置
WECHAT_PAY_MCH_ID=your_mch_id_here
WECHAT_PAY_API_KEY=your_api_key_here
WECHAT_PAY_NOTIFY_URL=https://api.yourdomain.com/api/v1/payment/wechat/notify

# 腾讯地图 SDK Key（请在腾讯位置服务申请）
TENCENT_MAP_SDK_KEY=your_tencent_map_sdk_key_here

# MinIO 配置
MINIO_ENDPOINT=localhost
MINIO_BUCKET_NAME=haircut-uploads
MINIO_USE_SSL=false

# 前端 API 地址（开发环境）
VITE_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# 站点域名（生产环境）
SITE_DOMAIN=https://www.your-haircut.com
